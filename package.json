{
  "name": "acptoapi",
  "version": "0.1.5",
  "description": "OpenAI-compatible HTTP facade over ACP (Kilo Code + opencode) — point any OpenAI SDK at it.",
  "type": "module",
  "bin": {
    "acptoapi": "bin/acptoapi.js"
  },
  "main": "lib/server.js",
  "exports": {
    ".": "./lib/server.js",
    "./translate": "./lib/translate.js",
    "./acp-client": "./lib/acp-client.js"
  },
  "files": [
    "bin",
    "lib",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/acptoapi.js",
    "test": "node test.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AnEntrypoint/acptoapi.git"
  },
  "keywords": [
    "acp",
    "openai",
    "kilo",
    "opencode",
    "proxy",
    "sdk"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
