# Provider API Keys
# Set any combination  - the server auto-detects which are available
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
CEREBRAS_API_KEY=
SAMBANOVA_API_KEY=
MISTRAL_API_KEY=
CODESTRAL_API_KEY=
ZAI_API_KEY=
QWEN_API_KEY=
OPENCODE_ZEN_API_KEY=
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=  # Required when CLOUDFLARE_API_KEY is set
GOOGLE_API_KEY=
GEMINI_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
FIREWORKS_API_KEY=

# Fallback priority order (comma-separated provider names)
# Default: anthropic,openrouter,groq,nvidia,cerebras,sambanova,mistral,codestral,qwen,zai,cloudflare,gemini,ollama
# PROVIDER_ORDER=groq,nvidia,openrouter

# Optional local Ollama endpoint
OLLAMA_URL=http://localhost:11434

# Optional local LibreChat aggregator endpoint (self-hosted OpenAI-compat frontend)
# LIBRECHAT_API_KEY only needed if the LibreChat instance requires auth
LIBRECHAT_URL=http://localhost:3040/v1
LIBRECHAT_API_KEY=

# Server auth key (leave blank to disable; REQUIRED if ACPTOAPI_BIND is non-loopback)
# ACPTOAPI_API_KEY is the canonical name; AGENTAPI_API_KEY accepted as legacy alias.
ACPTOAPI_API_KEY=

# Bind address (default: 127.0.0.1 / loopback only). Set to 0.0.0.0 to expose
# on LAN, but then ACPTOAPI_API_KEY MUST also be set or anyone on the network
# can spend your provider API keys.
# ACPTOAPI_BIND=127.0.0.1
