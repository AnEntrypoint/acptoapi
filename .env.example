# Provider API Keys
# Set any combination — the server auto-detects which are available
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
CEREBRAS_API_KEY=
SAMBANOVA_API_KEY=
MISTRAL_API_KEY=
CODESTRAL_API_KEY=
ZAI_API_KEY=
QWEN_API_KEY=
OPENCODE_ZEN_API_KEY=
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=  # Required when CLOUDFLARE_API_KEY is set
GOOGLE_API_KEY=
GEMINI_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
FIREWORKS_API_KEY=

# Fallback priority order (comma-separated provider names)
# Default: anthropic,openrouter,groq,nvidia,cerebras,sambanova,mistral,codestral,qwen,zai,cloudflare,gemini,ollama
# PROVIDER_ORDER=groq,nvidia,openrouter

# Optional local Ollama endpoint
OLLAMA_URL=http://localhost:11434

# Server auth key (leave blank to disable)
AGENTAPI_API_KEY=

# Telegram/Slack/Discord bot tokens (optional integrations)
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
DISCORD_BOT_TOKEN=
